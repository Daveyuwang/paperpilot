# ── LLM (server default; can be overridden in-app per guest) ───────────────
# Supported protocols: openai | openai_compatible | anthropic | gemini
LLM_PROTOCOL=anthropic
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# ── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=paperpilot
POSTGRES_PASSWORD=paperpilot
POSTGRES_DB=paperpilot
DATABASE_URL=postgresql+asyncpg://paperpilot:paperpilot@postgres:5432/paperpilot
DATABASE_URL_SYNC=postgresql://paperpilot:paperpilot@postgres:5432/paperpilot

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Qdrant (local Docker Compose default) ──────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=paperpilot_chunks
# For cloud Qdrant, uncomment these and remove the local host/port above:
# QDRANT_URL=https://your-cluster.region.cloud.qdrant.io:6333
# QDRANT_API_KEY=your_qdrant_api_key

# ── External APIs ──────────────────────────────────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=
TAVILY_API_KEY=

# ── App ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173

# ── Frontend (Docker Compose overrides; host browser → localhost services) ─
# VITE_API_URL=http://localhost:8000
# VITE_WS_URL=ws://localhost:8000
INLINE_INGESTION=false

# ── Upload limits ──────────────────────────────────────────────────────────
# UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50
MAX_UPLOAD_PAGES=200

# ── Feature Flags ──────────────────────────────────────────────────────
ENABLE_INTENT_ROUTING=true
WEB_SEARCH_ENABLED=true

# ── Models ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# Deprecated (kept only for older deployments; prefer LLM_* above)
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=

# ── Observability (Langfuse) ──────────────────────────────────────────────
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
ENABLE_TRACING=false
