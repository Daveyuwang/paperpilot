# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=paperpilot
POSTGRES_PASSWORD=paperpilot
POSTGRES_DB=paperpilot
DATABASE_URL=postgresql+asyncpg://paperpilot:paperpilot@postgres:5432/paperpilot
DATABASE_URL_SYNC=postgresql://paperpilot:paperpilot@postgres:5432/paperpilot

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Qdrant (local Docker Compose default) ──────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=paperpilot_chunks
# For cloud Qdrant, uncomment these and remove the local host/port above:
# QDRANT_URL=https://your-cluster.region.cloud.qdrant.io:6333
# QDRANT_API_KEY=your_qdrant_api_key

# ── External APIs ──────────────────────────────────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=

# ── App ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173

# ── Frontend (Docker Compose overrides; host browser → localhost services) ─
# VITE_API_URL=http://localhost:8000
# VITE_WS_URL=ws://localhost:8000
INLINE_INGESTION=false

# ── Feature Flags ──────────────────────────────────────────────────────
ENABLE_INTENT_ROUTING=true
WEB_SEARCH_ENABLED=true

# ── Models ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
CLAUDE_MODEL=claude-sonnet-4-6
